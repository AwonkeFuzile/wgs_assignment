
workDir = "/users/user08/work"

params {
  fastq     = "data/*_{1,2}.fastq.gz"
  reference = "data/chr19.fa"
  outdir    = "./results"
}

process {
  executor = 'local'
  scratch  = true
  cleanup  = true

  // Load HPC modules globally for non-container steps
  beforeScript = '''
    module purge
    module load fastqc
    module load bwa
    module load samtools
    module load bcftools
    module load cutadapt
  '''

  // Trimmomatic runs in your container (no modules inside this step)
  withName: 'TRIMMOMATIC' {
    cpus   = 2
    memory = '5 GB'
    time   = '1h'
    container = 'trimmomatic.sif'
    beforeScript = ''
  }
}

profiles {
  local { process.executor = 'local' }
  slurm { process.executor = 'slurm'; process.queue = 'Main' }
}

singularity {
  enabled    = true
  autoMounts = true
}

